rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: product ID (e.g., aura-pro-1)
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - price: number (required)
    //   - description: string (required)
    //   - images: list (required)
    //   - tagline: string
    //   - originalPrice: number
    //   - benefits: list
    //   - rating: number
    //   - reviewCount: number
    //   - stock: number
    //   - category: string
    //   - discountPercent: number
    //   - videoUrl: string
    //   - sizes: list (optional)
    //   - colors: list (optional)
    //
    // Collection: orders
    // Document ID: order ID
    // Fields:
    //   - customerName: string (required)
    //   - phone: string (required)
    //   - wilaya: string (required)
    //   - commune: string (required)
    //   - total: number (required)
    //   - status: string (required, 'pending' | 'confirmed' | 'shipped')
    //   - date: string (required)
    //   - items: list (required)
    //
    // Collection: settings
    // Document ID: 'global'
    // Fields:
    //   - delivery: map
    //   - promo: map
    //   - communes: map
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "akrambnahmed32@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'description', 'images']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.description is string && data.description.size() < 10000 &&
             data.images is list && data.images.size() > 0 && data.images.size() <= 20;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'phone', 'wilaya', 'commune', 'total', 'status', 'date', 'items']) &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 20 &&
             data.wilaya is string &&
             data.commune is string &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'confirmed', 'shipped'] &&
             data.items is list && data.items.size() > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if isValidOrder(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /settings/global {
      allow read: if true; // Publicly readable for delivery prices
      allow write: if isAdmin();
    }

    match /settings/anderson {
      allow read, write: if isAdmin();
    }
  }
}
